"""
Single-Cell RNA-seq Analysis of COVID-19 BALF Samples
Dataset: GSE145926 (Liao et al. 2020, Nature Medicine)
Author: Aysha Khenza U
"""

import scanpy as sc
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import os
import warnings
warnings.filterwarnings('ignore')

# Configure Scanpy
sc.settings.verbosity = 1  # progress messages
sc.settings.set_figure_params(dpi=150, facecolor='white', figsize=(8, 6))
sc.settings.autosave = True
sc.settings.figdir = './figures/'

# Create output directories
os.makedirs('figures', exist_ok=True)
os.makedirs('results', exist_ok=True)

print("COVID-19 SINGLE-CELL RNA-SEQ ANALYSIS")
print("\nLibraries loaded")
print("Directories created")


# Sample metadata from the paper
# Maps GSM accession IDs to patient IDs and clinical info

samples = {
    'GSM4339769': 'C141',  # Moderate COVID-19
    'GSM4339770': 'C142',
    'GSM4339771': 'C143',
    'GSM4339772': 'C144',
    'GSM4339773': 'C145',
    'GSM4339774': 'C146',
    'GSM4475051': 'C148',  # Severe COVID-19
    'GSM4475052': 'C149',
    'GSM4475053': 'C152',
    'GSM4475048': 'C51',   # Healthy
    'GSM4475049': 'C52',
    'GSM4475050': 'C100',
}

# Clinical annotations
sample_info = {
    'C51':  ('Healthy', 'Control'),
    'C52':  ('Healthy', 'Control'),
    'C100': ('Healthy', 'Control'),
    'C141': ('COVID-19', 'Moderate'),
    'C142': ('COVID-19', 'Moderate'),
    'C143': ('COVID-19', 'Moderate'),
    'C144': ('COVID-19', 'Moderate'),
    'C145': ('COVID-19', 'Moderate'),
    'C146': ('COVID-19', 'Moderate'),
    'C148': ('COVID-19', 'Severe'),
    'C149': ('COVID-19', 'Severe'),
    'C152': ('COVID-19', 'Severe'),
}

print("DATASET COMPOSITION")
print(f"Healthy controls:   {sum(1 for v in sample_info.values() if v[0] == 'Healthy')}")
print(f"Moderate COVID-19:  {sum(1 for v in sample_info.values() if v[1] == 'Moderate')}")
print(f"Severe COVID-19:    {sum(1 for v in sample_info.values() if v[1] == 'Severe')}")
print(f"Total patients:     {len(sample_info)}")

# Load all samples
print("LOADING H5 FILES")

adata_list = []

for gsm_id, patient_id in samples.items():
    filename = f"{gsm_id}_{patient_id}_filtered_feature_bc_matrix.h5"
    filepath = os.path.join('data', filename)
    
    if not os.path.exists(filepath):
        print(f"WARNING: Missing {filename}")
        continue
    
    print(f"Loading {patient_id:4s} ... ", end='')
    
    # Read 10X Genomics H5 file
    adata_sample = sc.read_10x_h5(filepath)
    adata_sample.var_names_make_unique()
    
    # Add metadata to each cell
    adata_sample.obs['sample'] = gsm_id
    adata_sample.obs['patient'] = patient_id
    adata_sample.obs['condition'] = sample_info[patient_id][0]
    adata_sample.obs['severity'] = sample_info[patient_id][1]
    
    adata_list.append(adata_sample)
    print(f"{adata_sample.n_obs:>7,} cells")

print(f"\nLoaded {len(adata_list)} samples successfully")

# Combine all samples into one object
print("COMBINING SAMPLES")

adata = sc.concat(
    adata_list,
    join='outer',
    label='batch',
    keys=[s.obs['sample'].iloc[0] for s in adata_list]
)

adata.var_names_make_unique()

print(f"\nCombined dataset:")
print(f"  Total cells:  {adata.n_obs:>8,}")
print(f"  Total genes:  {adata.n_vars:>8,}")

print(f"\nCondition breakdown:")
print(adata.obs['condition'].value_counts())

print(f"\nSeverity breakdown:")
print(adata.obs['severity'].value_counts())

# Create summary table
summary = (adata.obs
           .groupby(['patient', 'condition', 'severity'])
           .size()
           .reset_index(name='cells')
           .sort_values('cells', ascending=False))

print("CELLS PER PATIENT")
print(summary.to_string(index=False))


# Create bar plot showing cells per patient

fig, ax = plt.subplots(figsize=(12, 5))

color_map = {'Healthy': '#4682B4', 'COVID-19': '#FA8072'}
colors = [color_map[c] for c in summary['condition']]

bars = ax.bar(
    range(len(summary)),
    summary['cells'],
    color=colors,
    edgecolor='black',
    linewidth=0.8,
    alpha=0.85
)

ax.set_xticks(range(len(summary)))
ax.set_xticklabels(summary['patient'], rotation=45, ha='right', fontsize=10)
ax.set_ylabel('Number of Cells', fontsize=12, fontweight='bold')
ax.set_xlabel('Patient ID', fontsize=12, fontweight='bold')
ax.set_title('Cell Distribution per Patient',
             fontsize=14, fontweight='bold', pad=15)

# Add value labels on bars
for bar, cells in zip(bars, summary['cells']):
    height = bar.get_height()
    ax.text(bar.get_x() + bar.get_width()/2, height + 500,
            f'{cells:,}', ha='center', va='bottom', fontsize=9, fontweight='bold')

# Legend
from matplotlib.patches import Patch
legend_elements = [
    Patch(facecolor='#4682B4', edgecolor='black', label='Healthy'),
    Patch(facecolor='#FA8072', edgecolor='black', label='COVID-19')
]
ax.legend(handles=legend_elements, loc='upper right', fontsize=11, framealpha=0.95)

ax.grid(axis='y', alpha=0.3, linestyle='--', linewidth=0.7)
ax.set_axisbelow(True)
ax.spines['top'].set_visible(False)
ax.spines['right'].set_visible(False)

plt.tight_layout()
plt.savefig('figures/01_patient_distribution.png', dpi=300, bbox_inches='tight')
plt.show()

print("Figure saved: figures/01_patient_distribution.png")


# QUALITY CONTROL

print("QUALITY CONTROL")

# Identify mitochondrial genes
# These start with 'MT-' in human genome
adata.var['mt'] = adata.var_names.str.startswith('MT-')

print(f"\nMitochondrial genes detected: {adata.var['mt'].sum()}")

# Calculate QC metrics for each cell
sc.pp.calculate_qc_metrics(
    adata,
    qc_vars=['mt'],
    percent_top=None,
    log1p=False,
    inplace=True
)

print("\nQC metrics calculated:")
print("  n_genes_by_counts = number of genes detected per cell")
print("  total_counts = total RNA molecules (UMIs) per cell")
print("  pct_counts_mt = percentage of mitochondrial RNA")

# Display statistics
print("\nPRE-FILTERING STATISTICS")

print("\nGenes per cell:")
print(f"  Minimum: {adata.obs['n_genes_by_counts'].min():.0f}")
print(f"  Median:  {adata.obs['n_genes_by_counts'].median():.0f}")
print(f"  Maximum: {adata.obs['n_genes_by_counts'].max():.0f}")

print("\nCounts per cell (UMIs):")
print(f"  Minimum: {adata.obs['total_counts'].min():.0f}")
print(f"  Median:  {adata.obs['total_counts'].median():.0f}")
print(f"  Maximum: {adata.obs['total_counts'].max():.0f}")

print("\nMitochondrial percentage:")
print(f"  Minimum: {adata.obs['pct_counts_mt'].min():.2f}%")
print(f"  Median:  {adata.obs['pct_counts_mt'].median():.2f}%")
print(f"  Maximum: {adata.obs['pct_counts_mt'].max():.2f}%")


# Create QC visualization plots

fig, axes = plt.subplots(2, 3, figsize=(15, 10))

# Plot 1: Genes per cell histogram
axes[0, 0].hist(adata.obs['n_genes_by_counts'], bins=100, color='steelblue', edgecolor='black')
axes[0, 0].set_xlabel('Genes per cell', fontweight='bold')
axes[0, 0].set_ylabel('Number of cells', fontweight='bold')
axes[0, 0].set_title('Distribution: Genes per Cell', fontweight='bold')
axes[0, 0].axvline(200, color='red', linestyle='--', linewidth=2, label='Min threshold (200)')
axes[0, 0].axvline(5000, color='orange', linestyle='--', linewidth=2, label='Max threshold (5000)')
axes[0, 0].legend(fontsize=8)
axes[0, 0].set_xlim(0, 6000)

# Plot 2: Total counts histogram
axes[0, 1].hist(adata.obs['total_counts'], bins=100, color='coral', edgecolor='black')
axes[0, 1].set_xlabel('Total counts (UMIs)', fontweight='bold')
axes[0, 1].set_ylabel('Number of cells', fontweight='bold')
axes[0, 1].set_title('Distribution: Total Counts', fontweight='bold')

# Plot 3: Mitochondrial percentage histogram
axes[0, 2].hist(adata.obs['pct_counts_mt'], bins=100, color='salmon', edgecolor='black')
axes[0, 2].set_xlabel('Mitochondrial %', fontweight='bold')
axes[0, 2].set_ylabel('Number of cells', fontweight='bold')
axes[0, 2].set_title('Distribution: Mitochondrial %', fontweight='bold')
axes[0, 2].axvline(20, color='red', linestyle='--', linewidth=2, label='Max threshold (20%)')
axes[0, 2].legend(fontsize=8)
axes[0, 2].set_xlim(0, 50)

# Plot 4: Genes vs Counts scatter
axes[1, 0].scatter(adata.obs['total_counts'], adata.obs['n_genes_by_counts'],
                   s=1, alpha=0.3, c='steelblue')
axes[1, 0].set_xlabel('Total counts', fontweight='bold')
axes[1, 0].set_ylabel('Genes detected', fontweight='bold')
axes[1, 0].set_title('Genes vs Total Counts', fontweight='bold')
axes[1, 0].set_xscale('log')
axes[1, 0].set_yscale('log')

# Plot 5: MT% vs Counts scatter
axes[1, 1].scatter(adata.obs['total_counts'], adata.obs['pct_counts_mt'],
                   s=1, alpha=0.3, c='coral')
axes[1, 1].set_xlabel('Total counts', fontweight='bold')
axes[1, 1].set_ylabel('Mitochondrial %', fontweight='bold')
axes[1, 1].set_title('MT% vs Total Counts', fontweight='bold')
axes[1, 1].set_xscale('log')
axes[1, 1].axhline(20, color='red', linestyle='--', linewidth=1)

# Plot 6: MT% vs Genes scatter
axes[1, 2].scatter(adata.obs['n_genes_by_counts'], adata.obs['pct_counts_mt'],
                   s=1, alpha=0.3, c='salmon')
axes[1, 2].set_xlabel('Genes detected', fontweight='bold')
axes[1, 2].set_ylabel('Mitochondrial %', fontweight='bold')
axes[1, 2].set_title('MT% vs Genes', fontweight='bold')
axes[1, 2].set_xscale('log')
axes[1, 2].axhline(20, color='red', linestyle='--', linewidth=1)

plt.suptitle('QC Metrics - Pre-Filtering', fontsize=16, fontweight='bold', y=1.00)
plt.tight_layout()
plt.savefig('figures/02_qc_metrics_prefilter.png', dpi=300, bbox_inches='tight')
plt.show()

print("Figure saved: figures/02_qc_metrics_prefilter.png")


# Apply quality control filters

print("APPLYING FILTERS")

n_cells_before = adata.n_obs
n_genes_before = adata.n_vars

print(f"\nBefore filtering:")
print(f"  Cells: {n_cells_before:,}")
print(f"  Genes: {n_genes_before:,}")

# Filter 1: Minimum genes per cell (removes empty droplets)
print("\nFiltering cells...")
n_before = adata.n_obs
sc.pp.filter_cells(adata, min_genes=200)
print(f"  Min genes (200):      removed {n_before - adata.n_obs:>6,} cells")

# Filter 2: Maximum genes per cell (removes doublets)
n_before = adata.n_obs
adata = adata[adata.obs['n_genes_by_counts'] < 5000, :]
print(f"  Max genes (5000):     removed {n_before - adata.n_obs:>6,} cells")

# Filter 3: Maximum mitochondrial percentage (removes dying cells)
n_before = adata.n_obs
adata = adata[adata.obs['pct_counts_mt'] < 20, :]
print(f"  Max MT% (20):         removed {n_before - adata.n_obs:>6,} cells")

# Filter 4: Minimum cells per gene (removes rarely expressed genes)
print("\nFiltering genes...")
n_before = adata.n_vars
sc.pp.filter_genes(adata, min_cells=3)
print(f"  Min cells (3):        removed {n_before - adata.n_vars:>6,} genes")

n_cells_after = adata.n_obs
n_genes_after = adata.n_vars

print("\nPOST-FILTERING SUMMARY")
print(f"\nCells: {n_cells_after:,} ({n_cells_after/n_cells_before*100:.1f}% retained)")
print(f"Genes: {n_genes_after:,} ({n_genes_after/n_genes_before*100:.1f}% retained)")

print("\nPost-filtering statistics:")
print(f"  Genes per cell - Median: {adata.obs['n_genes_by_counts'].median():.0f}, Mean: {adata.obs['n_genes_by_counts'].mean():.0f}")
print(f"  Counts per cell - Median: {adata.obs['total_counts'].median():.0f}, Mean: {adata.obs['total_counts'].mean():.0f}")
print(f"  MT% - Median: {adata.obs['pct_counts_mt'].median():.2f}%, Mean: {adata.obs['pct_counts_mt'].mean():.2f}%")

print(f"\nCondition breakdown:")
print(adata.obs['condition'].value_counts())

print(f"\nSeverity breakdown:")
print(adata.obs['severity'].value_counts())


# NORMALIZATION AND PREPROCESSING

print("NORMALIZATION AND PREPROCESSING")

# Save raw counts before normalization 
adata.raw = adata.copy()
print("\nSaved raw counts to adata.raw")

# Normalize to 10,000 counts per cell
sc.pp.normalize_total(adata, target_sum=1e4)
print("Normalized to 10,000 counts per cell")

# Log-transform: log(x + 1)
# This compresses the range and makes data more normally distributed
sc.pp.log1p(adata)
print("Log-transformed: log(x + 1)")

# Identify highly variable genes (HVGs)
# These genes vary the most across cells = most informative for cell type identification
sc.pp.highly_variable_genes(
    adata,
    min_mean=0.0125,
    max_mean=3,
    min_disp=0.5
)

n_hvg = adata.var['highly_variable'].sum()
print(f"\nHighly variable genes identified: {n_hvg:,} ({n_hvg/adata.n_vars*100:.1f}%)")

# Visualize HVGs
sc.pl.highly_variable_genes(adata, save='_hvg.png', show=True)
print("Figure saved: figures/filter_genes_dispersion_hvg.png")

# Subset to highly variable genes for downstream analysis
# This reduces memory usage and focuses on informative genes
adata_hvg = adata[:, adata.var['highly_variable']].copy()

print(f"\nSubset to highly variable genes:")
print(f"  Cells: {adata_hvg.n_obs:,}")
print(f"  Genes: {adata_hvg.n_vars:,}")

# Scale only the HVGs (much smaller matrix - fits in memory)
sc.pp.scale(adata_hvg, max_value=10)
print("\nScaled HVG data: mean=0, variance=1 per gene")

print("\nPREPROCESSING COMPLETE")
print("\nDatasets ready:")
print("  adata     - Full dataset (normalized, log-transformed)")
print("  adata_hvg - HVG subset (scaled, ready for PCA/clustering)")


# DIMENSIONALITY REDUCTION AND CLUSTERING

print("DIMENSIONALITY REDUCTION AND CLUSTERING")

# Temporarily disable autosave
sc.settings.autosave = False

# PCA: Principal Component Analysis
print("\nRunning PCA...")
sc.tl.pca(adata_hvg, svd_solver='arpack', n_comps=50)
print("PCA computed: 50 principal components")

# Build neighbor graph
print("\nBuilding neighbor graph...")
sc.pp.neighbors(adata_hvg, n_neighbors=15, n_pcs=30)
print("Neighbor graph built: k=15 neighbors, using 30 PCs")

# UMAP for visualization
print("\nComputing UMAP embedding...")
sc.tl.umap(adata_hvg)
print("UMAP computed: 2D projection created")

# Leiden clustering
print("\nPerforming Leiden clustering...")
sc.tl.leiden(adata_hvg, resolution=0.5)
n_clusters = adata_hvg.obs['leiden'].nunique()
print(f"Clustering complete: {n_clusters} clusters identified")

print("\nCluster sizes:")
cluster_counts = adata_hvg.obs['leiden'].value_counts().sort_index()
for cluster, count in cluster_counts.items():
    print(f"  Cluster {cluster:>2s}: {count:>6,} cells")

# Visualize results
print("\nCREATING VISUALIZATIONS")

# Create custom matplotlib figure
fig, axes = plt.subplots(1, 3, figsize=(18, 5))

# Get UMAP coordinates
umap_coords = adata_hvg.obsm['X_umap']

# Plot 1: Colored by clusters
scatter1 = axes[0].scatter(umap_coords[:, 0], umap_coords[:, 1],
                           c=adata_hvg.obs['leiden'].astype(int),
                           s=1, alpha=0.6, cmap='tab20')
axes[0].set_title('UMAP: Leiden Clusters', fontsize=14, fontweight='bold')
axes[0].set_xlabel('UMAP 1')
axes[0].set_ylabel('UMAP 2')
axes[0].axis('off')

# Plot 2: Colored by condition
condition_colors = {'Healthy': '#4682B4', 'COVID-19': '#FA8072'}
colors2 = [condition_colors[c] for c in adata_hvg.obs['condition']]
axes[1].scatter(umap_coords[:, 0], umap_coords[:, 1],
                c=colors2, s=1, alpha=0.6)
axes[1].set_title('UMAP: Condition', fontsize=14, fontweight='bold')
axes[1].set_xlabel('UMAP 1')
axes[1].set_ylabel('UMAP 2')
axes[1].axis('off')

# Add legend for condition
from matplotlib.patches import Patch
legend_elements = [
    Patch(facecolor='#4682B4', label='Healthy'),
    Patch(facecolor='#FA8072', label='COVID-19')
]
axes[1].legend(handles=legend_elements, loc='upper right', frameon=True)

# Plot 3: Colored by severity
severity_map = {'Control': 0, 'Moderate': 1, 'Severe': 2}
severity_numeric = [severity_map[s] for s in adata_hvg.obs['severity']]
scatter3 = axes[2].scatter(umap_coords[:, 0], umap_coords[:, 1],
                           c=severity_numeric, s=1, alpha=0.6, 
                           cmap='YlOrRd')
axes[2].set_title('UMAP: Severity', fontsize=14, fontweight='bold')
axes[2].set_xlabel('UMAP 1')
axes[2].set_ylabel('UMAP 2')
axes[2].axis('off')

# Add legend for severity
from matplotlib.patches import Patch
legend_elements_sev = [
    Patch(facecolor='#FFFFB2', label='Control'),
    Patch(facecolor='#FD8D3C', label='Moderate'),
    Patch(facecolor='#BD0026', label='Severe')
]
axes[2].legend(handles=legend_elements_sev, loc='upper right', frameon=True)

plt.tight_layout()
plt.savefig('figures/04_umap_overview.png', dpi=300, bbox_inches='tight')
plt.show()

print("\nFigure saved: figures/04_umap_overview.png")

# Re-enable autosave
sc.settings.autosave = True



# CELL TYPE ANNOTATION
print("CELL TYPE ANNOTATION")

# Find marker genes for each cluster
print("\nFinding marker genes for each cluster...")
sc.tl.rank_genes_groups(
    adata_hvg,
    groupby='leiden',
    method='t-test',
    use_raw=False
)
print("Marker genes identified")

# Display top 5 marker genes per cluster
print("\nTop 5 marker genes per cluster:")

for i in range(17):
    markers = sc.get.rank_genes_groups_df(adata_hvg, group=str(i))
    top_genes = markers.head(5)['names'].tolist()
    print(f"Cluster {i:2d}: {', '.join(top_genes)}")  # Changed {i:>2s} to {i:2d}

# Annotate based on canonical markers
# Based on known immune cell markers in lung BALF
cell_type_annotations = {
    '0': 'Alveolar Macrophages',
    '1': 'Inflammatory Macrophages',
    '2': 'T cells',
    '3': 'Activated Macrophages',
    '4': 'Alveolar Macrophages',
    '5': 'Activated/Cycling cells',
    '6': 'Complement Macrophages',
    '7': 'Heat Shock Response cells',
    '8': 'Antigen Presenting cells',
    '9': 'NK/T cells',
    '10': 'Plasma cells',
    '11': 'T cells',
    '12': 'Ciliated Epithelial',
    '13': 'Proliferating cells',
    '14': 'Secretory Epithelial',
    '15': 'Macrophages',
    '16': 'Plasma/Secretory cells'
}

# Add annotations to data
adata_hvg.obs['cell_type'] = adata_hvg.obs['leiden'].map(cell_type_annotations)

print("\nCELL TYPE DISTRIBUTION")
cell_type_counts = adata_hvg.obs['cell_type'].value_counts()
print(f"\n{len(cell_type_counts)} cell types identified:\n")
for i, (cell_type, count) in enumerate(cell_type_counts.items(), 1):
    pct = count / adata_hvg.n_obs * 100
    print(f"{i:>2d}. {cell_type:<30s} {count:>6,} cells ({pct:>5.1f}%)")

# Visualize cell types on UMAP
print("\nCREATING CELL TYPE VISUALIZATION")

fig, axes = plt.subplots(1, 2, figsize=(16, 6))

# Plot 1: UMAP with cell type labels
umap_coords = adata_hvg.obsm['X_umap']
unique_types = adata_hvg.obs['cell_type'].unique()
colors = plt.cm.tab20(range(len(unique_types)))
type_to_color = dict(zip(unique_types, colors))

for cell_type in unique_types:
    mask = adata_hvg.obs['cell_type'] == cell_type
    axes[0].scatter(umap_coords[mask, 0], umap_coords[mask, 1],
                    c=[type_to_color[cell_type]], s=1, alpha=0.6,
                    label=cell_type)

axes[0].set_title('UMAP: Cell Types', fontsize=14, fontweight='bold')
axes[0].set_xlabel('UMAP 1')
axes[0].set_ylabel('UMAP 2')
axes[0].axis('off')
axes[0].legend(bbox_to_anchor=(1.05, 1), loc='upper left', 
               fontsize=8, frameon=True, markerscale=3)

# Plot 2: Composition by condition
composition = pd.crosstab(
    adata_hvg.obs['cell_type'],
    adata_hvg.obs['condition'],
    normalize='columns'
) * 100

composition.T.plot(kind='bar', stacked=True, ax=axes[1],
                   colormap='tab20', width=0.7, edgecolor='black', linewidth=0.5)
axes[1].set_xlabel('Condition', fontsize=12, fontweight='bold')
axes[1].set_ylabel('Percentage of cells (%)', fontsize=12, fontweight='bold')
axes[1].set_title('Cell Type Composition by Condition', fontsize=14, fontweight='bold')
axes[1].legend(bbox_to_anchor=(1.05, 1), loc='upper left', fontsize=7)
axes[1].set_xticklabels(['COVID-19', 'Healthy'], rotation=0)

plt.tight_layout()
plt.savefig('figures/05_cell_type_annotation.png', dpi=300, bbox_inches='tight')
plt.show()

print("\nFigure saved: figures/05_cell_type_annotation.png")




# DIFFERENTIAL EXPRESSION ANALYSIS

print("DIFFERENTIAL EXPRESSION ANALYSIS")

# Copy annotations back to full dataset
adata.obs['cell_type'] = adata_hvg.obs['cell_type']
adata.obs['leiden'] = adata_hvg.obs['leiden']
adata.obsm['X_umap'] = adata_hvg.obsm['X_umap']

# Analyze T cells (largest cell type with both conditions)
print("\nAnalyzing T cells (COVID-19 vs Healthy)...")

adata_tcells = adata[adata.obs['cell_type'] == 'T cells'].copy()

print(f"T cells:")
print(f"  COVID-19: {(adata_tcells.obs['condition'] == 'COVID-19').sum():,}")
print(f"  Healthy:  {(adata_tcells.obs['condition'] == 'Healthy').sum():,}")

# Differential expression
sc.tl.rank_genes_groups(
    adata_tcells,
    groupby='condition',
    groups=['COVID-19'],
    reference='Healthy',
    method='wilcoxon',
    use_raw=True
)

result_tcells = sc.get.rank_genes_groups_df(adata_tcells, group='COVID-19')

print("\nTop 20 upregulated genes in COVID-19 T cells:")
for i, row in result_tcells.head(20).iterrows():
    print(f"{i+1:>2d}. {row['names']:<12s} LogFC: {row['logfoldchanges']:>6.2f}  p-adj: {row['pvals_adj']:.2e}")

# Save results
result_tcells.to_csv('results/DE_tcells_covid_vs_healthy.csv', index=False)
print("\nSaved: results/DE_tcells_covid_vs_healthy.csv")

# Visualize key interferon genes
print("\nVISUALIZING INTERFERON RESPONSE GENES")

key_genes = ['IFITM3', 'ISG15', 'MX1', 'IFIT1']

fig, axes = plt.subplots(2, 2, figsize=(12, 10))
axes = axes.flatten()

for idx, gene in enumerate(key_genes):
    if gene in adata.var_names:
        # Get expression values
        gene_expr = adata.raw[:, gene].X.toarray().flatten()
        
        # Create violin plot
        conditions = adata.obs['condition']
        covid_expr = gene_expr[conditions == 'COVID-19']
        healthy_expr = gene_expr[conditions == 'Healthy']
        
        parts = axes[idx].violinplot([healthy_expr, covid_expr], 
                                      positions=[1, 2], 
                                      showmeans=True, 
                                      showmedians=True)
        
        # Color the violins
        for pc in parts['bodies']:
            pc.set_facecolor('#4682B4')
            pc.set_alpha(0.7)
        
        axes[idx].set_xticks([1, 2])
        axes[idx].set_xticklabels(['Healthy', 'COVID-19'])
        axes[idx].set_ylabel('Expression (log)', fontweight='bold')
        axes[idx].set_title(f'{gene}', fontsize=12, fontweight='bold')
        axes[idx].grid(axis='y', alpha=0.3)

plt.tight_layout()
plt.savefig('figures/06_interferon_genes.png', dpi=300, bbox_inches='tight')
plt.show()

print("\nFigure saved: figures/06_interferon_genes.png")

# Summary statistics
print("\nKEY FINDINGS")
sig_genes = result_tcells[(result_tcells['pvals_adj'] < 0.01) & 
                          (result_tcells['logfoldchanges'].abs() > 2)]

print(f"\nSignificant genes in T cells (p<0.01, |logFC|>2): {len(sig_genes):,}")
